# ──────────────────────────────────────────────────────────────────────────────
# Polymarket Bot — Environment Configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────────────────────


# ── Trading mode ───────────────────────────────────────────────────────────────
# "paper"  → no real orders, logs and accounts everything locally (default, safe)
# "live"   → submits real limit orders to the Polymarket CLOB
TRADING_MODE=live
DYNAMIC_THRESHOLD=true

# ── Live API credentials (required when TRADING_MODE=live) ────────────────────
#
# How to obtain these:
#   1. Go to https://polymarket.com and connect your wallet (MetaMask / WalletConnect)
#   2. Open the CLOB API section: https://docs.polymarket.com/#authentication
#   3. Call POST /auth/api-key with your wallet signature to generate the three
#      API credentials below.
#   4. Your POLY_PRIVATE_KEY is your Polygon wallet private key (0x-prefixed hex).
#      Never share this — it controls your funds.
#
# Note: leave blank (or omit) when TRADING_MODE=paper — they are not read.
POLY_PRIVATE_KEY=
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=
# POLY_FUNDER_ADDRESS: the wallet address that holds your Polymarket positions.
#   This is the address shown on your Polymarket profile / in the share URL
#   (e.g. polymarket.com/profile/0xABC…).
#   The redeemer queries positions AND checks on-chain balances for this address.
#   If left blank, the address derived from POLY_PRIVATE_KEY is used instead.
#   IMPORTANT: POLY_PRIVATE_KEY must be the private key that controls this address
#   (i.e. the key whose public address matches POLY_FUNDER_ADDRESS).
POLY_FUNDER_ADDRESS=
POLY_SIGNATURE_TYPE=1

# ── Feed selection ─────────────────────────────────────────────────────────────
# false → synthetic GBM data (offline, for testing signal logic)
# true  → real Binance WebSocket bars + Polymarket CLOB order-book prices
#         (required for TRADING_MODE=live to make sense)
USE_REAL_FEEDS=true
LIMIT_PRICE_BUFFER=0.01  # (default 0.01)

# ── Account ────────────────────────────────────────────────────────────────────
# Starting USDC balance used for position sizing and portfolio accounting.
# For live trading set this to your actual deposited USDC balance — the bot
# will reconcile against the real CLOB balance every minute and override this.
ACCOUNT_BALANCE=52


# ── Risk controls ──────────────────────────────────────────────────────────────
# Maximum expected loss per trade as a fraction of account balance.
# e.g. 0.005 = 0.5% of $1000 = max $5 expected loss per trade
MAX_LOSS_PER_TRADE_FRAC=0.005

# Hard cap: largest single position as a fraction of account balance.
# e.g. 0.10 = 10% = max $100 on any one market when balance is $1000
MAX_POSITION_FRAC=0.10

# Maximum total exposure (sum of open positions) as a fraction of balance.
# e.g. 0.50 = 50% → bot will not open new positions beyond half the balance
# MAX_EXPOSURE_FRAC=0.50  # (default 0.50)

# Drawdown kill-switch: bot halts automatically if account balance drops this
# fraction below its peak value.  Set lower (e.g. 0.20) for tighter risk.
# e.g. 0.40 = halt if balance falls 40% from its highest point this session
MAX_DRAWDOWN_KILL_FRAC=0.40

# Minimum EV required to enter a trade (fraction, not percent).
# e.g. 0.08 = 8% edge required above fee-adjusted expected value
EV_THRESHOLD=0.12  # (default 0.08)


# ── Signal filters ─────────────────────────────────────────────────────────────
# PHASE_MIN_FRAC=0.33       # skip first 33% of market window (default)
# VOL_REGIME_MIN_BPS=0.8    # skip low-vol markets below 0.8 bps (default)
# VOL_RELATIVE_MIN=0.50     # skip if vol < 50% of median vol (default)
# DIST_MIN_BPS=3.0          # skip if price within 3 bps of strike (default)


# ── Timing ─────────────────────────────────────────────────────────────────────
# Bar aggregation window in seconds (real feeds always use 5 s).
# METRIC_INTERVAL_S=5       # (default 5)

# Number of bars to collect before the first trade is allowed.
# WARMUP_INTERVALS=6        # (default 6 = 30 s at 5-s bars)


# ── Safety flags ───────────────────────────────────────────────────────────────
# Set ENABLE_TRADING=true only when you are ready to trade with real capital.
# Both must be true for live orders: TRADING_MODE=live AND ENABLE_TRADING=true
DRY_RUN=false
ENABLE_TRADING=true


# ── Redemption (live mode auto-claim) ─────────────────────────────────────────
# Polygon RPC endpoint used to call redeemPositions() on the CTF contract.
# Free public endpoints (no API key needed):
#   https://polygon-bor-rpc.publicnode.com   ← recommended
#   https://polygon.llamarpc.com
#   https://polygon.drpc.org
# For higher reliability use a dedicated key:
#   https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com
# USDC contract on Polygon.  Default = native USDC (post-2024 Polymarket markets).
# If your markets were created before mid-2024, use USDC.e instead:
#   POLY_USDC_ADDRESS=0x2791Bca1f2de4661ED88A30C99A7a9449Aa84174
POLY_USDC_ADDRESS=
# Requires 'web3' package:  pip install web3
# Requires a small MATIC balance in the wallet for gas (~$0.001 per redeem)
